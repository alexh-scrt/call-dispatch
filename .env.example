# .env.example - Template environment file for call_dispatch.
# Copy this file to .env and fill in your actual credentials.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Twilio Credentials
# ---------------------------------------------------------------------------
# Your Twilio Account SID - found in the Twilio Console:
# https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio Auth Token - found in the Twilio Console:
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# The Twilio phone number to make outbound calls FROM (E.164 format):
TWILIO_PHONE_NUMBER=+15551234567

# ---------------------------------------------------------------------------
# OpenAI Credentials
# ---------------------------------------------------------------------------
# Your OpenAI API key - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI model to use for conversation and summarisation.
# Default: gpt-4o  (change to gpt-4-turbo, gpt-3.5-turbo, etc. as needed)
OPENAI_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Deepgram Credentials
# ---------------------------------------------------------------------------
# Your Deepgram API key - https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ---------------------------------------------------------------------------
# Server / Application Settings
# ---------------------------------------------------------------------------
# Host address for the Uvicorn server to bind to.
# Use 0.0.0.0 to accept connections on all interfaces.
HOST=0.0.0.0

# Port the Uvicorn server will listen on.
PORT=8000

# Publicly accessible base URL of this server.
# Twilio must be able to reach this URL to deliver webhook callbacks.
# Use a tunnelling tool such as ngrok during local development:
#   ngrok http 8000
# Then set this to your ngrok HTTPS URL, e.g.:
PUBLIC_BASE_URL=https://your-subdomain.ngrok.io

# ---------------------------------------------------------------------------
# Database Settings
# ---------------------------------------------------------------------------
# SQLite database file path. Relative paths are resolved from the working
# directory where you run the server.
DATABASE_URL=sqlite:///./call_dispatch.db

# ---------------------------------------------------------------------------
# Optional Tuning Parameters
# ---------------------------------------------------------------------------
# Maximum tokens for the AI agent response (controls verbosity of utterances).
AGENT_MAX_TOKENS=256

# Sampling temperature for the AI agent (0.0 = deterministic, 2.0 = very random).
AGENT_TEMPERATURE=0.4

# Maximum tokens for the post-call summariser.
SUMMARIZER_MAX_TOKENS=512

# Sampling temperature for the summariser (lower = more consistent output).
SUMMARIZER_TEMPERATURE=0.2

# Maximum duration of a call in seconds before it is forcibly terminated.
CALL_TIMEOUT_SECONDS=300

# Logging level: DEBUG, INFO, WARNING, ERROR, or CRITICAL.
LOG_LEVEL=INFO
